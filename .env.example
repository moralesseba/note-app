# .env.example — PLANTILLA de variables de entorno.
# Copia este archivo como ".env.local" y rellena con las claves de tu proyecto Supabase
# (Dashboard → Project Settings → API Keys).

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Correo del dueño: único correo aceptado en el registro (candado también en RLS)
VITE_OWNER_EMAIL=
