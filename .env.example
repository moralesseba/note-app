# .env.example — PLANTILLA de variables de entorno (los .env reales no se versionan).
#
# Desarrollo local: copia este archivo como ".env.local" y rellena los valores.
# Deploy en Vercel:  define estas mismas 3 variables en
#                    Project → Settings → Environment Variables.
#
# Valores desde tu proyecto Supabase (Dashboard → Project Settings → API Keys).
# Nota: estos valores viajan al navegador (prefijo VITE_) — la seguridad real
# la aplican las políticas RLS de la base de datos, no el secreto de las claves.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Correo del dueño: único correo aceptado por el candado (UI + función is_app_owner en la BD)
VITE_OWNER_EMAIL=
